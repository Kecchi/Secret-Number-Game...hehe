import random

secretNumber = random.randint(1, 20)
print ("I am thinking of a secret number hehe, between 1 and 20 hehe!")

# Game beginzzz

for guessesTaken in range(1, 7):
    print ("Take a guess, hehe.)
    guess = int(input())
    
    if guess < secretNumber:
        print ("Your guess is too low, hehe.")
    elif guess > secretNumber:
        print ("Your guess is too high, hehe.")
    else:
        break  # Correct guess
        
if guess == secretNumber:
    print ("HUH!? It cannot be...you guessed.......the secret.../nYou guessed in " + str(guessesTaken) + " guesses!")
    
else:
    print ("HeheheheHEHEHEHE. You'll never know my secret now!!! /n.../n......./n.......ok it was " + str(secretNumber))        